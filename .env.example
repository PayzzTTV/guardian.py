# .env.example — Template de configuration GuardianPy
# Copier ce fichier en .env et remplir avec vos vraies valeurs
# NE JAMAIS committer le fichier .env

# Niveau de log : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Mode simulation (true = aucune connexion réelle)
DRY_RUN=false

# MongoDB (Phase 2)
# MONGO_URI=mongodb://guardianpy_user:CHANGE_ME@localhost:27017/guardianpy
# MONGO_DB=guardianpy
